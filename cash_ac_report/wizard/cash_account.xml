<?xml version="1.0"?>
<odoo>

    <record id="cash_account_report_action_form" model="ir.ui.view">
        <field name="name">cash.account.report.wizard.form</field>
        <field name="model">cash.account.report.wizard</field>
        <field name="arch" type="xml">
            <form string="Cash A/c Report">
                <group>
                    <group>
                        <field name="date_from" required="1"/>
                    </group>
                    <group>
                        <field name="date_to" required="1"/>
                    </group>
                </group>
                <group>
                    <group>
                        <field name="account_id" options="{'no_create': True}" required="1"/>
                        <field name="company_id" readonly="1" invisible="1"/>
                        <field name="user_id" readonly="1" invisible="1"/>
                    </group>
                    <group>
                        <field name="is_account"/>
                        <field name="is_partner"/>
                        <field name="is_label"/>
                    </group>
                </group>
                <footer>
                    <button name="action_print_report" string="PDF" class="btn-primary" type="object"
                            icon="fa-print"/>
                    <button icon="fa-print" string="Excel" name="print_xl_report" type="object"
                            class="oe_highlight"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="cash_account_report_action" model="ir.actions.act_window">
        <field name="name">Cash A/c Report</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">cash.account.report.wizard</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="cash_account_report_action_form"/>
        <field name="target">new</field>
    </record>

    <menuitem id="cash_account_report_menu"
              name="Cash A/c Report"
              parent="account.account_reports_management_menu"
              action="cash_account_report_action"
              sequence="2"/>

</odoo>
