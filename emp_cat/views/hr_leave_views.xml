<?xml version='1.0' encoding='UTF-8' ?>
<odoo>
    <record id="edit_holiday_status_form_inherit_emp_cat" model="ir.ui.view">
        <field name="name">leave.form.inherit.emp.cat</field>
        <field name="model">hr.leave.type</field>
        <field name="inherit_id" ref="hr_holidays.edit_holiday_status_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='request_unit']" position="after">
                <field name="type_of_leave" widget="radio" options="{'horizontal': true}" string="Leave Type"/>
                <field name="is_paid_time_off" widget="boolean_toggle"/>
                <field name="is_unpaid_time_off" widget="boolean_toggle"/>

            </xpath>
        </field>
    </record>

    <record id="hr_leave_view_form_inherit_emp_cat" model="ir.ui.view">
        <field name="name">hr.leave.view.form.emp.cat</field>
        <field name="model">hr.leave</field>
        <field name="inherit_id" ref="hr_holidays.hr_leave_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//label[@for='request_unit_hours']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <field name="request_unit_hours" position="attributes">
                <attribute name="invisible">1</attribute>
            </field>
            <xpath expr="//field[@name='name']" position="before">
                <field name="type_of_leave" widget="radio" options="{'horizontal': true}" string="Leave Type"
                       readonly="1" force_save="1"/>
            </xpath>
        </field>
    </record>

</odoo>