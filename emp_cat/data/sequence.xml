<odoo>
    <record id="hr_employee_on_roll_sequence" model="ir.sequence">
      <field name="name">Employee On-Roll Sequence</field>
      <field name="code">hr.employee.on.roll</field>
      <field name="prefix">SM-HRD-</field>
      <field name="padding">4</field>
      <field name="number_next">1</field>
      <field name="number_increment">1</field>
    </record>
    <record id="hr_employee_contract_labour_sequence" model="ir.sequence">
      <field name="name">Employee Contract Labour Sequence</field>
      <field name="code">hr.employee.contract.labour</field>
      <field name="prefix">SM-HRD-CON-</field>
      <field name="padding">4</field>
      <field name="number_next">1</field>
      <field name="number_increment">1</field>
    </record>

</odoo>