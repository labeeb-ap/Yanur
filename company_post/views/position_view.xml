        <field name="arch" type="xml">
            <xpath expr="//header/button[@name='action_rfq_send'][1]" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//header/button[@name='action_rfq_send'][2]" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//header/button[@name='action_rfq_send'][3]" position="attributes">
                <!--                <attribute name="string">Approval</attribute>-->
                <attribute name="groups">company_post.purchase_order_approval</attribute>
                <attribute name="class">btn btn-primary</attribute>
                <!--                <attribute name="attrs">{'invisible': [('mail','=', True)]}</attribute>-->
                <!--                <attribute name="attrs">{'invisible': [('mail','=', True)]}</attribute>-->

            </xpath>
            <!--            <xpath expr="//field[@name='partner_id']" position="after">-->
            <!--                <field name="mail"/>-->
            <!--            </xpath>-->


            <!--            <xpath expr="//header/button[@name='action_rfq_send'][2]" states="purchase" position="attributes">-->
            <!--                <attribute name="invisible">1</attribute>-->
            <!--            </xpath>-->


            <!--            <xpath expr="//header/button[@name='button_confirm']" position="attributes">-->
