<?xml version="1.0"?>
<odoo>

    <record id="day_book_report_action_form" model="ir.ui.view">
        <field name="name">day.book.report.wizard.form</field>
        <field name="model">day.book.report.wizard</field>
        <field name="arch" type="xml">
            <form string="Day Book Report">
                <group>
                    <group>
                        <field name="date" required="1"/>
                    </group>
                </group>
                <footer>
                    <button name="action_print_report" string="PDF Report" class="btn-primary" type="object"
                            icon="fa-print"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="day_book_report_action" model="ir.actions.act_window">
        <field name="name">Day Book</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">day.book.report.wizard</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="day_book_report_action_form"/>
        <field name="target">new</field>
    </record>

    <menuitem id="day_book_report_menu"
              name="Day Book"
              parent="account.account_reports_management_menu"
              action="day_book_report_action"
              sequence="4"/>

</odoo>
