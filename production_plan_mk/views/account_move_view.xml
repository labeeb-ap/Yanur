<?xml version="1.0"?>
<odoo>
    <record id="view_move_form_account_move_inherit_production_plan_mk" model="ir.ui.view">
        <field name="name">account.move.inherit.production.plan.mk</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='invoice_line_ids']/tree/field[@name='quantity']"
                   position="before">
                <field name="product_expiration" force_save="1" attrs="{'column_invisible': [('parent.move_type', 'not in', ('out_invoice'))]}" invisible="1"/>
<!--                <field name="box_count" readonly="1" force_save="1" attrs="{'column_invisible': [('parent.move_type', 'not in', ('out_invoice'))]}"/>-->
                <field name="box" attrs="{'column_invisible': [('parent.move_type', 'not in', ('out_invoice'))]}" invisible="1"/>
<!--                <field name="box" attrs="{'readonly': [('parent.move_type', 'not in', ('out_invoice'))]}"/>-->
            </xpath>
            <xpath expr="//field[@name='line_ids']/tree/field[@name='name']"
                   position="before">
            <field name="product_expiration" invisible="1"/>
            <field name="box_count" invisible="1"/>
            <field name="box" invisible="1"/>
            </xpath>
        </field>
    </record>
</odoo>
