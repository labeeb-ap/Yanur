<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="product_template_only_form_view_inherited_production_plan_mk" model="ir.ui.view">
        <field name="name">product.template.inherited.production.plan</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="arch" type="xml">
            <field name="uom_po_id" position="after">
                <field name="box" invisible="1"/>
                <label for="packing_per_carton"/>
                    <div>
                        <field name="packing_per_carton" class="oe_inline"/> &amp;nbsp; <field name="type_in_carton" class="oe_inline" invisible="1"/>
                    </div>
                <field name="picking_type_id" invisible="1"/>
<!--                <field name="product_expiration"/>-->
            </field>
            <field name="type" position="before">
                <field name="product_brand" invisible="1"/>
            </field>
        </field>
    </record>
</odoo>