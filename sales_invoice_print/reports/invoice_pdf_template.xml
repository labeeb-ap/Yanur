<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <template id="account_invoice_custom_report">
        <t t-call="web.basic_layout">
            <t t-call="web.html_container">
                <t t-foreach="docs" t-as="doc">
                    <style type="text/css">
                        #table_head_border{
                        vertical-align: middle;
                        border-right: 1px solid black;
                        border-left: 1px solid black;
                        border-top: 1px solid black;
                        border-bottom: 1px solid black;
                        }
                    </style>
                    <!--                    Header Content-->
                    <t t-set="order_id"
                       t-value="doc.invoice_line_ids.mapped('sale_line_ids.order_id') and doc.invoice_line_ids.mapped('sale_line_ids.order_id')[0] or None"/>
                    <div class="page">
                        <div class="header">
                            <table class="table table-borderless" width="100%">
                                <tr>
                                    <td width="70%" align="left" style="border-bottom: 2px solid black;">
                                        <img t-if="doc.company_id.logo" t-att-src="image_data_uri(doc.company_id.logo)"
                                             style="width:40%; max-height:140pt;" alt="Logo"/>
                                    </td>
                                    <td style="border-bottom: 2px solid black; vertical-align:top;">
                                        <span style="font-size: 20px; font-weight: bold;"
                                              t-field="doc.company_id.name"/>
                                        <br/>
                                        <span t-field="doc.company_id.street"/>
                                        <br/>
                                        <span t-field="doc.company_id.street2"/>
                                        <br/>
                                        <span t-field="doc.company_id.city"/>
                                        <span t-field="doc.company_id.state_id"/>
                                        <span t-field="doc.company_id.zip"/>
                                        <br/>
                                        <span>Tel/Fax:</span>
                                        <span t-field="res_company.partner_id.phone"/>
                                        <br/>
                                        <span t-field="res_company.partner_id.email"/>
                                    </td>
                                </tr>
                            </table>
                            <div style="font-size: 12px;" align="right">
                                Page&#160;&#160;<span class="page"/>&#160;of&#160;
                                <span class="topage"/>
                            </div>
                            <table class="table table-borderless" width="100%">
                                <tr>
                                    <td colspan="4" align="center" style="font-weight: bold;">Invoice Number&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;<span
                                            t-field="doc.name"/>
                                    </td>
                                </tr>
                                <tr>
                                    <td width="17%" style="border-bottom: 1px solid black; vertical-align: middle;">
                                        <b>Customer</b>
                                    </td>
                                    <td colspan="2" style="border-bottom: 1px solid black;"/>
                                    <td width="25%" align="center"
                                        style="border-bottom: 1px solid black; vertical-align: middle;">
                                        <b>Misc</b>
                                    </td>
                                </tr>
                                <tr>
                                    <td>Name</td>
                                    <td width="5%" style="font-weight: bold;">:</td>
                                    <td>
                                        <span t-field="doc.partner_id.name"/>
                                    </td>
                                    <td align="right">Date&#160;&#160;&#160;:&#160;&#160;&#160;<span
                                            t-field="doc.invoice_date"/>
                                    </td>
                                </tr>
                                <tr>
                                    <td>Address</td>
                                    <td style="font-weight: bold;">:</td>
                                    <td>
                                        <span t-field="doc.partner_id"
                                              t-options='{"widget": "contact", "fields": ["address", "mobile", "phone", "email"], "no_marker": True}'/>
                                    </td>
                                    <td rowspan="2" align="right">EO Number&#160;&#160;&#160;:&#160;&#160;&#160;<span
                                            t-esc="eo_number"/>
                                    </td>
                                </tr>
                                <tr>
                                    <td>Attention</td>
                                    <td style="font-weight: bold;">:</td>
                                    <td>
                                        <t t-if="order_id">
                                            <span t-esc="order_id.notes_notebook"/>
                                        </t>
                                    </td>
                                </tr>
                            </table>
                        </div>
                        <!--                    Header Content End-->
                        <!--                    Body Content-->
                        <t t-set="max_rows_per_page" t-value="10"/>
                        <t t-set="total_rows" t-value="len(vals)"/>
                        <t t-set="pages" t-value="range(0, total_rows, max_rows_per_page)"/>

                        <t t-foreach="pages" t-as="page_start">
                            <table width="100%" class="table table-borderless"
                                   style="border: 1px solid black; page-break-before: always; height:100mm;">
                                <thead>
                                    <tr>
                                        <td id="table_head_border" align="center" style="font-weight: bold;">Pax</td>
                                        <td id="table_head_border" style="font-weight: bold;">Description</td>
                                        <td id="table_head_border" align="center" style="font-weight: bold;">Quantity
                                        </td>
                                        <td id="table_head_border" align="right" style="font-weight: bold;">Price</td>
                                        <td id="table_head_border" align="right" style="font-weight: bold;">Total</td>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-foreach="vals[page_start:page_start + max_rows_per_page]" t-as="line">
                                        <t t-if="line['main_value'] == 1">
                                            <tr>
                                                <td align="center"
                                                    style="border-right: 1px solid black; vertical-align: top;">
                                                    <span t-esc="'%.2f'%line['pax']"/>
                                                </td>
                                                <td style="border-right: 1px solid black; vertical-align: top; font-weight: bold;">
                                                    <span t-esc="line['description']"/>
                                                </td>
                                                <td align="center"
                                                    style="border-right: 1px solid black; vertical-align: top;">
                                                    <span t-esc="'%.2f'%line['quantity']"/>
                                                </td>
                                                <td align="right"
                                                    style="border-right: 1px solid black; vertical-align: top;">
                                                    <span t-esc="'%.2f'%line['price']"/>
                                                </td>
                                                <td align="right" style="vertical-align: top;">
                                                    <span t-esc="'%.2f'%line['total']"/>
                                                </td>
                                            </tr>
                                        </t>
                                        <t t-else="">
                                            <tr>
                                                <td valign="top"
                                                    style="border-right: 1px solid black; padding: 0px 0px 0px 7px;"/>
                                                <td valign="top"
                                                    style="border-right: 1px solid black; padding: 0px 0px 0px 7px;">
                                                    <span t-esc="line['description']"/>
                                                </td>
                                                <td valign="top"
                                                    style="border-right: 1px solid black; padding: 0px 0px 0px 7px;"/>
                                                <td valign="top"
                                                    style="border-right: 1px solid black; padding: 0px 0px 0px 7px;"/>
                                                <td valign="top" style="padding: 0px 0px 0px 7px;"/>
                                            </tr>
                                        </t>
                                    </t>
                                    <!-- Fill remaining rows up to max_rows_per_page -->
                                    <t t-set="current_row_count"
                                       t-value="len(vals[page_start:page_start + max_rows_per_page])"/>
                                    <t t-if="current_row_count &lt; max_rows_per_page">
                                        <t t-foreach="range(max_rows_per_page - current_row_count)" t-as="empty_row">
                                            <tr>
                                                <td style="border-right: 1px solid black;"/>
                                                <td style="border-right: 1px solid black;"/>
                                                <td style="border-right: 1px solid black;"/>
                                                <td style="border-right: 1px solid black;"/>
                                                <td/>
                                            </tr>
                                        </t>
                                    </t>
                                </tbody>
                            </table>
                        </t>
                        <!--                    Body Content End-->
                        <!--                                                        Footer Content-->
                        <div class="footer">
                            <t t-set="paid_tot_amount"
                               t-value="sum(payment['amount'] for payment in doc.sudo()._get_reconciled_info_JSON_values() or [])"/>
                            <table width="100%" class="table table-borderless"
                                   style="border: 1px solid black; font-weight: bold;">
                                <tr>
                                    <td width="70%">
                                        <p>InWords&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;
                                            <span t-esc="doc.currency_id.with_context(lang='es_AR').amount_to_text(doc.amount_total)"/>
                                            Only
                                        </p>
                                    </td>
                                    <td width="20%" align="right">Sub
                                        Total&#160;&#160;<span
                                                t-field="doc.currency_id.symbol"/>&#160;&#160;:
                                    </td>
                                    <td align="right">
                                        <span t-esc="'%.2f'% doc.sub_total"/>
                                    </td>
                                </tr>
                                <tr>
                                    <td>
                                        Discount Remarks
                                    </td>
                                    <td align="right">Misc Amount&#160;&#160;<span
                                            t-field="doc.currency_id.symbol"/>&#160;&#160;:
                                    </td>
                                    <td align="right">
                                        <span t-esc="'%.2f'% doc.additional_amount"/>
                                    </td>
                                </tr>
                                <tr>
                                    <td colspan="2" align="right">Net Amount&#160;&#160;<span
                                            t-field="doc.currency_id.symbol"/>&#160;&#160;:
                                    </td>
                                    <td align="right">
                                        <span t-esc="'%.2f'% doc.amount_total"/>
                                    </td>
                                </tr>
                                <tr>
                                    <td colspan="2" align="right" style="font-weight: 900;">Paid Amount&#160;&#160;<span
                                            t-field="doc.currency_id.symbol"/>&#160;&#160;:
                                    </td>
                                    <td align="right" style="font-weight: 900;">
                                        <span t-esc="'%.2f'% paid_tot_amount"/>
                                    </td>
                                </tr>
                                <tr>
                                    <td colspan="2" align="right" style="font-weight: 900;">Balance
                                        Amount&#160;&#160;<span
                                                t-field="doc.currency_id.symbol"/>&#160;&#160;:
                                    </td>
                                    <td align="right" style="font-weight: 900;">
                                        <span t-esc="'%.2f'% doc.amount_residual"/>
                                    </td>
                                </tr>
                            </table>
                            <table width="100%" class="table table-borderless"
                                   style="border: 1px solid black; font-weight: bold;">
                                <tr>
                                    <td width="15%"
                                        style="border-left: 1px solid black; border-right: 1px solid black; border-top: 1px solid black; border-bottom: 1px solid black;">
                                        Payment
                                    </td>
                                    <td>
                                        Please remit the Payment to:
                                    </td>
                                    <td width="45%"
                                        style="border-left: 1px solid black; border-right: 1px solid black; border-top: 1px solid black;"/>
                                </tr>
                                <tr>
                                    <td>Account No</td>
                                    <td>
                                        :
                                        <span t-field="doc.company_id.acc_bank_name"/>
                                    </td>
                                    <td style="border-left: 1px solid black;">Venue&#160;&#160;&#160;:&#160;&#160;&#160;
                                        <span t-esc="venue_name"/>
                                    </td>
                                </tr>
                                <tr>
                                    <td>Account Name</td>
                                    <td>
                                        :
                                        <span t-field="doc.company_id.acc_number"/>
                                    </td>
                                    <td style="border-left: 1px solid black;">Sales Man&#160;&#160;&#160;:&#160;&#160;&#160;
                                        <span t-esc="sales_man_name"/>
                                    </td>
                                </tr>
                                <tr>
                                    <td colspan="2"
                                        style="padding-top: 20px; padding-bottom: 20px; border-left: 1px solid black; border-right: 1px solid black; border-top: 1px solid black; border-bottom: 1px solid black;">
                                        Received By
                                    </td>
                                    <td style="padding-top: 20px; padding-bottom: 20px; font-weight: 900; border-left: 1px solid black; border-right: 1px solid black; border-top: 1px solid black; border-bottom: 1px solid black;">
                                        <span t-field="doc.company_id.name"/>
                                    </td>
                                </tr>
                            </table>
                            <table width="100%" class="table table-borderless">
                                <tr>
                                    <td style="padding: 0px 0px 0px 0px;">
                                        <u>Terms &amp; conditions</u>
                                    </td>
                                </tr>
                                <tr>
                                    <td style="padding: 0px 0px 0px 0px;">
                                        1. If there is any complaint regarding the function or setup, Customer should
                                    inform it to the
                                    operation or marketing team within 12 hrs after the event take place.
                                    </td>
                                </tr>
                                <tr>
                                    <td style="padding: 0px 0px 0px 0px;">
                                        2. Confirm menu before 2 days.
                                    </td>
                                </tr>
                                <tr>
                                    <td style="padding: 0px 0px 0px 0px;">
                                        3. Payment should be made before the event.
                                    </td>
                                </tr>
                            </table>
                        </div>
                    </div>
                    <!--                    Footer Content End-->
                </t>
            </t>
        </t>
    </template>
</odoo>
