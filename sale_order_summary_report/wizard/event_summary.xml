<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="event_ord_form" model="ir.ui.view">
        <field name="name">event.order.summary.form</field>
        <field name="model">event.order.summary</field>
        <field name="arch" type="xml">
            <form string="Most Selling Product">
                <group>
                    <group>
                        <field name="from_date" required='True'/>
                    </group>
                    <group>
                        <field name="to_date" required='True'/>
<!--                        <field name="company_id"/>-->
                    </group>
                </group>
                <footer>
                    <button icon="fa-print" string="PDF" name="print_pdf_report" type="object"
                            class="oe_highlight"/>
                    <button string="Cancel" class="oe_link" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
    <record id="event_order_summary_action" model="ir.actions.act_window">
        <field name="name">Most Selling Product</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">event.order.summary</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="view_id" ref="event_ord_form"/>
    </record>
    <menuitem id="event_order_summary_menu"
              name="Event order Summary"
              parent="sale.menu_sale_report"
              action="event_order_summary_action"
              sequence="10"/>

</odoo>