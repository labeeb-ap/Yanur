<?xml version="1.0" ?>
<odoo>
    <data noupdate="1">
      <record id="cheque_record_in_account_account_receipt" model="account.account">
          <field name="name">Outstanding Receipts Cheque</field>
        <field name="code">100221</field>
        <field name="user_type_id" ref="account.data_account_type_liquidity"/>
<!--        <field name="type_third_parties">no</field>-->
      </record>
      <record id="cheque_record_in_account_account_payment" model="account.account">
        <field name="name">Outstanding Payments Cheque</field>
        <field name="code">100222</field>
        <field name="user_type_id" ref="account.data_account_type_liquidity"/>
<!--        <field name="type_third_parties">no</field>-->
      </record>
      <record id="cheque_record_in_account_journal" model="account.journal">
        <field name="name">Cheque</field>
        <field name="type">bank</field>
        <field name="code">CHQ</field>
        <field name="payment_debit_account_id" ref="cheque_record_in_account_account_receipt"/>
        <field name="payment_credit_account_id" ref="cheque_record_in_account_account_payment"/>
      </record>
    </data>
</odoo>