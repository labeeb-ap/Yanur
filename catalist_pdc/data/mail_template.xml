<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data noupdate="0">
    <record id="pdc_mail_template" model="mail.template">
      <field name="name">Post Dated Cheques</field>
      <field name="model_id" ref="catalist_pdc.model_account_payment"/>
      <field name="subject">Current Dated Cheques</field>
      <field name="email_from">${user.email_formatted | safe}</field>
      <field name="body_html" type="html">
<div style="margin: 0px; padding: 0px;">
    <p style="margin: 0px; padding: 0px; font-size: 13px;">
        Dear sir,
        <br/>
        Today is the date of the Cheque.
        <br/>
            Thanks &amp; Regards,
        <br/>Catalist Support Team
    </p>
</div>
      </field>
      <field name="lang">${object.partner_id.lang}</field>
    </record>

  </data>
</odoo>
