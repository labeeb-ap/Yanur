<odoo>
    <record id="pos_session_close_wizard_form_view" model="ir.ui.view">
        <field name="name">pos.session.close.wizard.form</field>
        <field name="model">pos.session.close.wizard</field>
        <field name="arch" type="xml">
            <form string="Attendance Report">
                <p class="oe_grey">
                    You Can Select date for the closed sessions.
                </p>
                <group>
                    <group class="oe_title">
                        <field name="date" required="1"/>
                    </group>
                    <footer>
                        <button name="session_close" string="Done" type="object" class="btn-primary"
                        />
                        <button string="Cancel" class="btn-secondary" special="cancel"/>
                    </footer>
                </group>
            </form>
        </field>
    </record>

<!--    <record id="view_pos_details_wizard" model="ir.ui.view">-->
