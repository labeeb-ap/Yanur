<!--                <group>-->
<!--                        <field name="start_date" required="1"/>-->
<!--                        <field name="end_date" required="1"/>-->
<!--                </group>-->
<!--            </form>-->
<!--        </field>-->
<!--    </record>-->
    <record id="pos_session_close_wizard_action" model="ir.actions.act_window">
        <field name="name">Session Close</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">pos.session.close.wizard</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="pos_session_close_wizard_form_view"/>
        <field name="target">new</field>
    </record>

    <menuitem id="pos_session_close_wizard_main"
              name="Close Session"
              parent="point_of_sale.menu_point_root"
              sequence="2"
    />
    <menuitem id="pos_session_close_wizard_sub"
              name="Session Close"
              parent="pos_session_close_wizard_main"
              action="pos_session_close_wizard_action"
              sequence="0"
    />

</odoo>