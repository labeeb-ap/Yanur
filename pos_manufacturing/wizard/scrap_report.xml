<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="scrap_report_form" model="ir.ui.view">
        <field name="name">scrap.report.form</field>
        <field name="model">scrap.report</field>
        <field name="arch" type="xml">
            <form string ="Scrap Report">
                <group>
                    <group>
                        <field name = "from_date" required = 'True'/>
                        <field name = "to_date" required = 'True'/>
                    </group>
                </group>
                <footer>
                    <button icon="fa-print" string="XLSX" name="scrap_report_xlsx" type="object"
                            class="oe_highlight"/>
                    <button string="Cancel" class="oe_link" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="scrap_report_action" model="ir.actions.act_window">
        <field name="name">Scrap Report</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">scrap.report</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="view_id" ref="scrap_report_form"/>
    </record>

    <menuitem id="scrap_report_menu"
              name="Scrap Report"
              parent="mrp.menu_mrp_reporting"
              action="scrap_report_action"
              sequence="10"/>
</odoo>