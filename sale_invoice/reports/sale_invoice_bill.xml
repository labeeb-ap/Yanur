<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <data>
        <record id="paperformat_euro_lowmargin_sales_invoice_print_pdf" model="report.paperformat">
            <field name="name">European A4 low margin</field>
            <field name="default" eval="True"/>
            <field name="format">A4</field>
            <field name="page_height">0</field>
            <field name="page_width">0</field>
            <field name="orientation">Portrait</field>
            <field name="margin_top">0</field>
            <field name="margin_bottom">50</field>
            <field name="header_line" eval="False"/>
        </record>

        <record id="record_sales_invoice_report_print" model="ir.actions.report">
            <field name="name">Sales Invoice</field>
            <field name="model">account.move</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">sale_invoice.sales_invoice_report_print</field>
            <field name="report_file">sale_invoice.sales_invoice_report_print</field>
            <field name="paperformat_id" ref="sale_invoice.paperformat_euro_lowmargin_sales_invoice_print_pdf"/>
            <field name="binding_model_id" ref="account.model_account_move"/>
            <field name="binding_view_types">list,form</field>
            <field name="binding_type">report</field>
        </record>
    </data>
</odoo>