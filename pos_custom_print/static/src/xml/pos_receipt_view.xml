                        <!--                            <span t-esc="env.pos.format_currency(receipt.discount_amt)" class="pos-receipt-right-align"/>-->
                                            </div>
                                        </t>
                <t t-else="">
                                        <div>
                                            Discount
                                            <span t-esc="env.pos.format_currency(disc)"
                                                  class="pos-receipt-right-align"/>
                                            <!--                                        With a <t t-esc=""/>% discountval-->


                                            <!--                            <span t-esc="receipt.payload" class="pos-receipt-right-align"/>-->
