<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-name="PasswordInputPopup" owl="1">
        <div role="dialog" class="modal-dialog">
            <div class="popup">
                <header class="title">
                    <t t-esc="props.title"/>
                </header>
                <div class="div">
                    <div class="flex-justify-content">
                        <div>
                             <textarea
                                 id="text_area"
                                 rows="2"
                                 cols="30"
                                 t-model="state.displayValue"
                                 t-ref="textarea"
                                 t-on-input="onInput"/>
                        </div>
                    </div>
                </div>
                <div class="footer">
                    <div class="button-group">
                        <div class="button cancel" t-on-click="cancelPopup" style="width:75px;height:11px;line-height:11px;padding:10px 10px;background-color: #89807f">
                            <t t-esc="props.cancelText"/>
                        </div>
                        <div class="button confirm" t-on-click="confirm_ref" style="width:75px;height:11px;line-height:11px;padding:10px 10px;background-color:#27ae60">
                            <t t-esc="props.confirmText"/>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </t>
</templates>
