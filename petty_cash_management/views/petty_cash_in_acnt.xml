<?xml version="1.0" encoding="UTF-8" ?>
<odoo>

    <record id="petty_cash_acnt_form" model="ir.ui.view">
        <field name="name">Select Petty Cash</field>
        <field name="model">account.account</field>
        <field name="inherit_id" ref="account.view_account_form"/>
        <field name="arch" type="xml">
            <field name="deprecated" position="after">
                <field name="petty_cash_selection"/>
                <field name="journal_id" attrs="{'invisible': [('petty_cash_selection','=',False)]}"/>
            </field>
        </field>
    </record>

</odoo>