<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="culinary_quantity_form" model="ir.ui.view">
        <field name="name">culinary.quantity.form</field>
        <field name="model">culinary.quantity</field>
        <field name="arch" type="xml">
            <form string="Chef's Prep List">
                <group>
                    <group>
                        <field name="from_date" required='True'/>
                    </group>
                    <group>
                        <field name="to_date" required='True'/>
                    </group>
                </group>
                <footer>
                    <button icon="fa-print" string="PDF" name="print_pdf_report" type="object"
                            class="oe_highlight"/>
                    <button string="Cancel" class="oe_link" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
    <record id="culinary_quantity_action" model="ir.actions.act_window">
        <field name="name">Culinary Quantity List</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">culinary.quantity</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="view_id" ref="culinary_quantity_form"/>
    </record>
    <menuitem id="culinary_quantity_menu"
              name="Culinary Quantity List"
              parent="sale.menu_sale_report"
              action="culinary_quantity_action"
              sequence="10"/>
</odoo>