<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="group_exit_clearance_approval_button" model="res.groups">
            <field name="name">Exit Clearance Approval</field>
        </record>

        <record id="group_employee_exit_clearance_approval" model="res.groups">
            <field name="name">Exit Clearance</field>
        </record>

        <record id="employee_exit_clearance_rule_records" model="ir.rule">
            <field name="name">Personal Exit Clearance</field>
            <field name="model_id" ref="model_employee_exit_clearance"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
            <field name="domain_force">[('user_id','=',user.id)]</field>
            <field name="groups" eval="[(4, ref('exit_clear.group_employee_exit_clearance_approval'))]"/>
        </record>

    </data>
</odoo>
