    <record model="ir.ui.view" id="crm_lead_kanban_view_custom">
        <field name="name">crm.lead.kanban.view.custom</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.crm_case_kanban_view_leads"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@class='o_kanban_record_title']" position="after">
                Expected Closing : <field name="date_deadline"/>
            </xpath>
        </field>
    </record>



    <record id="create_crm_quick_lead" model="ir.ui.view">
        <field name="name">create.crm.quick.lead</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.quick_create_opportunity_form"/>
        <field name="arch" type="xml">

            <xpath expr="//field[@name='phone']" position="after">
                <field name="event_date" required="1"/>
                <field name="venue" required="1"/>
<!--                <field name="per_head_price"/>-->
<!--                <field name="min_no_person"/>-->
            </xpath>
            <xpath expr="//label[@for='expected_revenue']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//field[@name='expected_revenue']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
        </field>
    </record>

    <record id="contact_form" model="ir.ui.view">
        <field name="name">contact.form</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='category_id']" position="after">
                <field name="ic_number"/>
            </xpath>
        </field>
    </record>

    <menuitem id="daily_sales_report_menu"
              name="Receivables"
              parent="crm.crm_menu_root"
              action="account.action_move_out_invoice_type"
              groups="event_order.group_receivables"
              sequence="10"/>

</odoo>