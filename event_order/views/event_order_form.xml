                <attribute name="attrs">{'readonly':[('state','in',['sale','done'])]}</attribute>

            </xpath>

            <xpath expr="//notebook/page[@name='order_lines']" position="after">
                <page string="Additional Rental Orders">
                    <field name="rental_item_ids">
                        <tree editable="bottom">
                            <field name="rental_product" required="1"/>
                            <field name="description"/>
                            <field name="product_quantity"/>
                            <field name="product_price"/>
                            <field name="product_sub_total"/>
                        </tree>
