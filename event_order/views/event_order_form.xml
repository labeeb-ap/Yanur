    <record id="sale_order_tree_view_event_order" model="ir.ui.view">
        <field name="name">sale.order.tree.view.event.order</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='state']" position="before">
                <field name="venue" optional="hide"/>
                <field name="ph_no" optional="hide"/>
                <field name="ic_number_customer" optional="hide"/>
                <field name="email_id" optional="hide"/>
                <field name="fax" optional="hide"/>
                <field name="nature_of_function" optional="hide"/>

                <field name="notes" optional="hide"/>
                <field name="location_id" optional="hide"/>
                <field name="discount_type" optional="hide"/>
                <field name="discount_amount" optional="hide"/>
<!--                <field name="food_type" optional="hide"/>-->
                <field name="price_amount" optional="hide"/>
                <field name="price_amount_min" optional="hide"/>
                <field name="pax_child_amount" optional="hide"/>
                <field name="pax_child_qty" optional="hide"/>

                <field name="discount_line" optional="hide"/>
            </xpath>
            <xpath expr="//field[@name='amount_total']" position="before">
                <field name="event_title" optional="show"/>
                <field name="additional_amount" optional="show"/>
            </xpath>
        </field>
    </record>

