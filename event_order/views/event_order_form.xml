<odoo>

    <record id="sale_order_form_view_custom" model="ir.ui.view">
        <field name="name">sale.order.form.view.custom</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='partner_id']" position="after">
                <field name="venue" required="1" attrs="{'readonly':[('state','in',['done','sale'])]}"/>
                <field name="ph_no" attrs="{'readonly':[('state','in',['done','sale'])]}"/>
                <field name="ic_number_customer" attrs="{'readonly':[('state','in',['done','sale'])]}"/>
                <field name="email_id" attrs="{'readonly':[('state','in',['done','sale'])]}"/>
                <field name="fax" attrs="{'readonly':[('state','in',['done','sale'])]}"/>
            </xpath>

            <xpath expr="//div[@class='o_row']" position="after">
                <field name="notes" attrs="{'readonly':[('state','in',['done','sale'])]}"/>
                <field name="nature_of_function" attrs="{'readonly':[('state','in',['done','sale'])]}"/>
                <field name="location_id" attrs="{'readonly':[('state','in',['done','sale'])]}"/>
                <field name="discount_type" force_save="1" groups="event_order.group_pos_discount_user"/>
                <field name="discount_amount" attrs="{'invisible': [('discount_type', '=', False)]}" force_save="1"
                       groups="event_order.group_pos_discount_user"/>
<!--                <field name="food_type" attrs="{'readonly':[('state','in',['done','sale'])]}"/>-->
                <field name="price_amount" required="1" force_save="1"
                       attrs="{'readonly':[('state','in',['done','sale'])]}"/>
                <field name="price_amount_min" required="1" force_save="1"
                       attrs="{'readonly':[('state','in',['done','sale'])]}"/>
                <field name="pax_child_amount" force_save="1"
                       attrs="{'readonly':[('state', 'in', ['sale', 'done'])],'invisible': [('company_id', '=', 5)]}"/>
                <field name="pax_child_amount"
                       string="Price per VIP pax"
                       force_save="1"
                       attrs="{
               'readonly': [('state', 'in', ['sale', 'done'])],
               'invisible': [('company_id', '!=', 5)]
           }"/>
                <field name="pax_child_qty" force_save="1"
                       attrs="{'readonly':[('state', 'in', ['sale', 'done'])],'invisible': [('company_id', '=', 5)]}"/>
                <field name="pax_child_qty" string="No Of VIP Pax" force_save="1"
                       attrs="{'readonly':[('state', 'in', ['sale', 'done'])],'invisible': [('company_id', '!=', 5)]}"/>

            </xpath>
            <!--            <xpath expr="//field[@name='order_line']/tree/field[@name='name']" position="after">-->
            <!--                <field name="is_rental_item" optional="hide"/>-->
            <!--            </xpath>-->

            <xpath expr="//field[@name='date_order']" position="attributes">
                <attribute name="string">Order Date</attribute>
            </xpath>

            <xpath expr="//field[@name='amount_untaxed']" position="after">
                <field name="additional_amount"/>
                <field name="discount_line" force_save="1" attrs="{'invisible': [('discount_type', '=', False)]}"
                       groups="event_order.group_pos_discount_user"/>

            </xpath>
            <xpath expr="//notebook" position="before">
                <button string="Add Multiple Products" name="%(open_view_multiple_product_sale_action)d" type="action"
                        class="oe_highlight" attrs="{'invisible': [('state', 'in', ['sale', 'done', 'cancel'])]}"/>
            </xpath>

            <xpath expr="//field[@name='payment_term_id']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <xpath expr="//field[@name='validity_date']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <xpath expr="//field[@name='order_line']/tree/field[@name='product_uom_qty']" position="attributes">
                <attribute name="required">0</attribute>
            </xpath>

            <xpath expr="//field[@name='order_line']/tree/field[@name='price_unit']" position="attributes">
                <attribute name="required">0</attribute>
            </xpath>

            <xpath expr="//field[@name='order_line']/tree/field[@name='price_subtotal']" position="attributes">
                <attribute name="required">0</attribute>
            </xpath>

            <xpath expr="//field[@name='order_line']/tree/field[@name='name']" position="attributes">
                <attribute name="required">0</attribute>
            </xpath>

            <xpath expr="//field[@name='order_line']/tree/field[@name='product_uom']" position="attributes">
                <attribute name="required">0</attribute>
            </xpath>
            <xpath expr="//field[@name='order_line']/tree/field[@name='price_unit']" position="attributes">
                <attribute name="groups">event_order.group_unit_price</attribute>
            </xpath>
            <xpath expr="//field[@name='order_line']/tree/field[@name='price_subtotal']" position="attributes">
                <attribute name="groups">event_order.group_subtotal</attribute>
            </xpath>
            <xpath expr="//field[@name='order_line']/tree/field[@name='name']" position="after">
                <field name="addi_true" optional="hide" readonly="1" force_save="1"/>
            </xpath>
            <xpath expr="//button[@name='preview_sale_order']" position="attributes">
                <attribute name="invisible">1</attribute>
