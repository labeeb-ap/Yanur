    <record id="account_tax_view" model="ir.ui.view">
        <field name="name">account.tax.view</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='journal_div']" position="after">
                <field name="price_amount" readonly="1" force_save="1"/>
                <field name="price_amount_min" readonly="1" force_save="1"/>
                <field name="pax_child_amount" readonly="1" force_save="1"/>
                <field name="pax_child_qty" readonly="1" force_save="1"/>
            </xpath>
            <xpath expr="//field[@name='invoice_line_ids']/tree/field[@name='name']" position="after">
                <field name="is_rental_item" force_save="1" readonly="1" optional="hide"/>
            </xpath>
            <xpath expr="//field[@name='invoice_line_ids']/tree/field[@name='tax_ids']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//field[@name='invoice_line_ids']/tree/field[@name='price_unit']" position="attributes">
                <attribute name="groups">event_order.group_unit_price</attribute>
            </xpath>

            <xpath expr="//field[@name='invoice_line_ids']/tree/field[@name='price_subtotal']" position="attributes">
                <attribute name="groups">event_order.group_subtotal</attribute>
            </xpath>

            <!--            <xpath expr="//field[@name='line_ids']/tree/field[@name='tax_tag_ids']" position="after">-->
            <!--                <field name="event_type" optional="hide"/>-->
            <!--            </xpath>-->

            <xpath expr="//field[@name='amount_untaxed']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//field[@name='discount']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//field[@name='discount_line_type']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//field[@name='invoice_date']" position="attributes">
                <attribute name="attrs">{'required':[('move_type','=','out_receipt')]}</attribute>
            </xpath>

            <xpath expr="//field[@name='amount_total']" position="before">
                <field name="additional_amount" attrs="{'invisible':[('move_type', '!=', 'out_invoice')]}"/>
                <field name="sub_total" attrs="{'invisible':[('move_type', '!=', 'out_invoice')]}"/>
                <field name="discount" attrs="{'invisible':[('move_type', '!=', 'out_invoice')]}"
                       groups="event_order.group_pos_discount_user"/>
            </xpath>

            <xpath expr="//field[@name='payment_reference']" position="before">
                <field name="event_id" attrs="{'required':[('move_type','=','out_invoice')]}"/>
                <field name="compl_food_pric"/>
                <field name="food_tast"/>
            </xpath>
            <xpath expr="//field[@name='line_ids']/tree/field[@name='tax_tag_ids']" position="after">
                <field name="event_type_id" optional="hide"/>

            </xpath>


            <xpath expr="//field[@name='payment_reference']" position="before">
                <field name="event_date" attrs="{'invisible':[('move_type', '!=', 'out_invoice')]}"/>
                <!--                <field name="event_type"/>-->
                <!--                <field name="compl_food_pric"/>-->
                <!--                <field name="food_tast"/>-->

            </xpath>

            <xpath expr="//field[@name='amount_total']" position="attributes">
                <attribute name="string">Net Amount</attribute>
            </xpath>
            <xpath expr="//field[@name='amount_residual']" position="attributes">
                <attribute name="string">Balance Amount</attribute>
            </xpath>

        </field>
    </record>

    <record id="account_tax_view_tree" model="ir.ui.view">
        <field name="name">account.tax.view.tree</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_out_invoice_tree"/>
        <field name="arch" type="xml">

            <field name="invoice_date" position="after">
                <field name="event_date"/>
            </field>

            <field name="name" position="after">
                <field name="invoice_origin" string="Event Reference"/>
            </field>
            <field name="payment_state" position="after">
                <field name="amount_residual"/>
            </field>


        </field>
    </record>


</odoo>