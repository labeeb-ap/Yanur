<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="sale_order_form_view_compliment_add" model="ir.ui.view">
        <field name="name">sale.order.form.view.custom</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">

            <xpath expr="//notebook/page[@name='other_information']" position="before">
                <page string="Complementry Details" name="complementory_detsils"
                      attrs="{'invisible': [('company_id', '!=', 5)]}"
                >
                    <field name="complimentory_food_new_id">
                        <tree editable="bottom">
                            <field name="complimentory_food"/>
                            <field name="complimentory_food_qty"/>
                            <field name="total_pax_com"/>
                            <field name="complementry_price_per_pax"/>
                            <field name="venue_com"/>
                            <field name="events_date_complementory"/>
                            <field name="event_time_complementory"/>
                            <field name="event_time_ynr_complementory"/>
                        </tree>
                    </field>
                    <field name="complimentory_food_note"  placeholder="Complimentory Food Note..."/>
                </page>

            </xpath>
            <xpath expr="//notebook/page[@name='other_information']" position="before">
                <page string="Food Tasting Details" name="food_tastin"
                      attrs="{'invisible': [('company_id', '!=', 5)]}"
                >
                    <field name="food_tasting_ids">
                        <tree editable="bottom">
                            <field name="tasting_food_id"/>
                            <field name="total_pax_tasting"/>
                            <field name="price_per_pax_tasting"/>
                            <field name="venue_tasting"/>
                            <field name="tasting_date"/>
                            <field name="tasting_time"/>
                            <field name="tasting_time_period"/>
                            <!--                            <field name="event_time_ynr_complementory"/>-->
                        </tree>
                    </field>
                    <field name="food_tasting_note"  placeholder="Food Tasting Note..."/>
                </page>

            </xpath>


            <xpath expr="//notebook/page[@name='other_information']" position="before">
                <page string="Vip Food Details" name="vip_food_tastin"
                      attrs="{'invisible': [('company_id', '!=', 5)]}"
                >
                    <field name="vip_food_details_ids">
                        <tree editable="bottom">
                            <field name="vip_id"/>
                        </tree>
                    </field>
                    <field name="vip_food_note"  placeholder="VIP Food Note..."/>

                </page>

            </xpath>


        </field>
    </record>
</odoo>