<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="additional_input_rule_tree" model="ir.ui.view">
            <field name="name">additional.input.rule.tree</field>
            <field name="model">additional.input.rule</field>
            <field name="priority" eval="8"/>
            <field name="arch" type="xml">
                <tree string="Additional Input Rule">
                    <field name="rule_id"/>
                    <field name="date"/>
                </tree>
            </field>
        </record>
        <record id="additional_input_rule_form" model="ir.ui.view">
            <field name="name">additional.input.rule.form</field>
            <field name="model">additional.input.rule</field>
            <field name="priority" eval="8"/>
            <field name="arch" type="xml">
                <form string="Employee Resignation">
                    <sheet>
                        <group>
                            <group>
                                <field name="rule_id"/>
                            </group>
                            <group>
                                <field name="date"/>
                                <field name="company_id" invisible="1"/>
                            </group>
                            <group><button name="generate_employee_lines" type="object" string="Generate Employees" class="oe_highlight"/></group>
                        </group>

                        <notebook>
                            <page string="Lines" name="rule_line_ids">
                            <field name="input_rule_line_ids">
                                <tree string="Rule lines"
                                      editable="bottom">
                                    <field name="company_id" invisible="1"/>
                                    <field name="employee_id"/>
                                    <field name="barcode" readonly="1"/>
                                    <field name="amount"/>
                                    </tree>
                            </field>
                        </page>
                    </notebook>

                    </sheet>
                    <div class="oe_chatter">
                        <field name="message_follower_ids" widget="mail_followers"/>
                        <field name="message_ids" widget="mail_thread"/>
                    </div>
                </form>
            </field>
        </record>

        <record model="ir.actions.act_window" id="additional_input_rule_action">
            <field name="name">Additional Input Rule</field>
            <field name="res_model">additional.input.rule</field>
            <field name="view_mode">tree,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">Create a new input rule.</p>
            </field>
        </record>
        <menuitem id="additional_input_rule_action_menu"
                  parent="om_hr_payroll.menu_hr_payroll_configuration"
                  name="Additional Input Rule"
                  action="additional_input_rule_action"
                  groups="base.group_user"
                  sequence="1"/>
    </data>
</odoo>


