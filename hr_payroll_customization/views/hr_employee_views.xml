<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_employee_form_inherit_hr_payroll_customization" model="ir.ui.view">
        <field name="name">payroll.hr.employee.view.form</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
                <xpath expr="//page[@name='hr_settings']" position="after">
                    <page string="Salary input rule" name="rule_line_ids">
                            <field name="input_rule_line_ids">
                                <tree string="Rule lines"
                                      editable="bottom">
                                    <field name="company_id" invisible="1"/>
                                    <field name="employee_id"/>
                                    <field name="rule_id"/>
                                    <field name="amount"/>
                                    </tree>
                            </field>
                        </page>
                </xpath>
        </field>
    </record>
</odoo>