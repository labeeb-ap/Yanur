<?xml version="1.0" encoding="utf-8"?>
<odoo>
	<record id="pos_config_cash_drawer_form_view" model="ir.ui.view">
		<field name="name">pos.config.cash.drawer.form.inherit</field>
		<field name="model">pos.config</field>
		<field name="inherit_id" ref="point_of_sale.pos_config_view_form"/>
		<field name="arch" type="xml">
			<xpath expr="//div[@id='category_reference']/.." position="after">
                <h2>POS Configuration For Static IP Address</h2>
                    <div class="row mt16 o_settings_container" id="posbox_reference">
                        <div class="col-12 col-lg-6 o_setting_box">
                            <div class="o_setting_left_pane">
                                <field name="is_sale_cash_drawer"/>
                            </div>
                            <div class="o_setting_right_pane">
                                <span class="o_form_label">Static IP Address</span>
                                <div class="text-muted">
                                    Static IP Address
                                </div>
                                <div class="content-group" attrs="{'invisible': [('is_sale_cash_drawer', '=', False)]}">
                                    <div class="row mt16">
                                        <label string="IP Address" for="ip_address" class="col-lg-3 o_light_label"/>
                                        <field name="ip_address" attrs="{'required': [('is_sale_cash_drawer', '!=', False)]}"/>
                                    </div>
                                    <div class="row mt16">
                                        <label string="Printer Name" for="printer_name" class="col-lg-3 o_light_label"/>
                                        <field name="printer_name" attrs="{'required': [('is_sale_cash_drawer', '!=', False)]}"/>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
            </xpath>
		</field>
	</record>
</odoo>