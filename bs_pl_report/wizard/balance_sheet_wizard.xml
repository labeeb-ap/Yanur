<?xml version="1.0"?>
<odoo>

    <record id="balance_sheet_report_wizard_action_form" model="ir.ui.view">
        <field name="name">balance.sheet.report.wizard.form</field>
        <field name="model">balance.sheet.report.wizard</field>
        <field name="arch" type="xml">
            <form string="Balance Sheet">
                <group>
                    <group>
                        <field name="start_date" required="1"/>
                    </group>
                    <group>
                        <field name="end_date" required="1"/>
                    </group>
                    <group>
                        <field name="company_ids" widget="many2many_tags" options="{'no_create': True}"/>
                    </group>
                    <group>
                        <field name="detailed_summary"/>
                    </group>
                </group>
                <footer>
                    <button name="print_pdf_report" string="PDF" class="btn-primary" type="object"
                            icon="fa-print"/>
                    <button icon="fa-print" string="Excel" name="print_xl_report" type="object"
                            class="oe_highlight"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="balance_sheet_report_wizard_action" model="ir.actions.act_window">
        <field name="name">Balance Sheet</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">balance.sheet.report.wizard</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="balance_sheet_report_wizard_action_form"/>
        <field name="target">new</field>
    </record>

    <menuitem id="balance_sheet_report_wizard_menu"
              name="Balance Sheet Report"
              parent="account.account_reports_management_menu"
              action="balance_sheet_report_wizard_action"
              sequence="4"/>

</odoo>
