<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>

        <record id="sale_order_form_view_inherit_base_fields_readonly" model="ir.ui.view">
            <field name="name">sale.order.form.view.base.fields.readonly</field>
            <field name="model">sale.order</field>
            <field name="inherit_id" ref="sale.view_order_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='l10n_in_gst_treatment']" position="attributes">
                    <attribute name="readonly">0</attribute>
                </xpath>
                <xpath expr="//field[@name='pricelist_id']" position="attributes">
                    <attribute name="readonly">0</attribute>
                </xpath>
                <xpath expr="//field[@name='payment_term_id']" position="attributes">
                    <attribute name="readonly">0</attribute>
                </xpath>
            </field>
        </record>

        <record id="sale_order_form_view_inherit_base_fields_with_readonly" model="ir.ui.view">
            <field name="name">sale.order.form.view.base.fields.with.readonly</field>
            <field name="model">sale.order</field>
            <field name="inherit_id" ref="sale.view_order_form"/>
            <field name="groups_id" eval="[(4, ref('hide_menu_user.group_sale_orders_readonly'))]"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='l10n_in_gst_treatment']" position="attributes">
                    <attribute name="readonly">1</attribute>
                </xpath>
                <xpath expr="//field[@name='pricelist_id']" position="attributes">
                    <attribute name="readonly">1</attribute>
                </xpath>
                <xpath expr="//field[@name='payment_term_id']" position="attributes">
                    <attribute name="readonly">1</attribute>
                </xpath>
            </field>
        </record>

    </data>
</odoo>