<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="profit_loss_form" model="ir.ui.view">
        <field name="name">profit.loss.form</field>
        <field name="model">profit.loss</field>
        <field name="arch" type="xml">
            <form string ="Profit and Loss Report">
                <group>
                    <group>
                        <field name = "from_date" required = 'True'/>
                        <field name = "to_date" required = 'True'/>
                    </group>
                    <group>
                        <field name = "company_ids" widget="many2many_tags" required ='True'/>


                    </group>
                </group>
                <footer>
                    <button icon="fa-print" string="XLSX" name="profit_loss_xlsx" type="object"
                            class="oe_highlight"/>
                    <button string="Cancel" class="btn" special="cancel" />
                </footer>
            </form>
        </field>
    </record>
    <record id="profit_loss_action" model="ir.actions.act_window">
        <field name="name">Profit And Loss Report</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">profit.loss</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="view_id" ref="profit_loss_form"/>
    </record>

    <menuitem id="profit_loss_report_menu"
              name="Profit and Loss Report"
              parent="account.menu_finance_reports"
              action="profit_loss_action"
              sequence="10"/>
</odoo>